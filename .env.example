# Database — use docker-compose.dev.yml for local dev
DATABASE_URL="postgresql://staybase:staybase@localhost:5432/staybase"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-generate-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Email — optional; falls back to console logging when unset
RESEND_API_KEY=""
EMAIL_FROM="StayBase <noreply@staybase.app>"

# App
APP_URL="http://localhost:3000"

# Cron jobs — protect /api/jobs/* endpoints
CRON_SECRET="change-me-generate-a-long-random-string"

# Dev bypass — set any password here to log in without a database (never set in production)
DEV_ADMIN_PASSWORD=""

# File storage — optional; falls back to local disk when unset
STORAGE_ENDPOINT=""
STORAGE_REGION=""
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_BUCKET=""
